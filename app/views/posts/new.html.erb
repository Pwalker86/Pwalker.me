<% content_for :title, "New Post" %>

<section class="sg-canvas relative overflow-hidden rounded-3xl p-5 sm:p-7 lg:p-10">
  <div aria-hidden="true" class="pointer-events-none absolute -top-16 right-0 h-56 w-56 rounded-full bg-[radial-gradient(circle,rgba(30,64,175,0.18)_0%,rgba(30,64,175,0)_70%)]"></div>

  <div class="relative mx-auto max-w-3xl space-y-6">
    <header class="space-y-3">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-slate-500">Compose</p>
      <h1 class="text-4xl font-semibold leading-tight text-slate-900">New post</h1>
      <p class="text-base leading-8 text-slate-700">Start as a draft or publish immediately. Slugs are generated from the title.</p>
    </header>

    <div class="sg-surface p-5 sm:p-7">
      <%= render "form", post: @post %>
    </div>
  </div>
</section>