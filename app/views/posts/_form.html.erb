<%= form_with model: post, class: "space-y-6" do |form| %>
  <% if post.errors.any? %>
    <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm text-amber-950">
      <p class="font-semibold">Please fix the following:</p>
      <ul class="mt-2 space-y-1">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "text-sm font-medium text-slate-700" %>
    <%= form.text_field :title, class: "mt-2 block w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-200" %>
  </div>

  <div>
    <%= form.label :body, class: "text-sm font-medium text-slate-700" %>
    <div class="mt-2 overflow-hidden rounded-2xl border border-slate-300 bg-white shadow-sm focus-within:border-blue-800 focus-within:ring-2 focus-within:ring-blue-200">
      <%= form.rich_text_area :body,
      class: "min-h-72 border-0",
      data: {
        controller: "trix-tab-lock",
        action: "keydown->trix-tab-lock#lockTab"
      } %>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-4">
    <div class="flex items-start gap-3">
      <%= form.check_box :published, class: "mt-1 h-4 w-4 rounded border-slate-300 text-blue-900 focus:ring-blue-300" %>
      <div>
        <%= form.label :published, "Publish this post", class: "text-sm font-medium text-slate-900" %>
        <p class="mt-1 text-sm text-slate-600">Published posts appear in the public index and are available at their slug URL.</p>
      </div>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <%= form.submit class: "inline-flex min-h-11 items-center justify-center rounded-full bg-blue-900 px-5 py-2.5 text-sm font-medium text-white transition duration-300 hover:-translate-y-0.5 hover:bg-blue-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-700" %>
    <%= link_to "Back to posts", posts_path, class: "rounded-full border border-slate-300 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-100" %>
  </div>
<% end %>