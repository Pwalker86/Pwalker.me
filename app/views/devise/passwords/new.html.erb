<section class="sg-canvas relative overflow-hidden rounded-3xl p-5 sm:p-7 lg:p-9">
  <div aria-hidden="true" class="pointer-events-none absolute -top-14 right-0 h-52 w-52 rounded-full bg-[radial-gradient(circle,rgba(245,158,11,0.22)_0%,rgba(245,158,11,0)_70%)]"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -bottom-16 -left-12 h-60 w-60 rounded-full bg-[radial-gradient(circle,rgba(30,64,175,0.2)_0%,rgba(30,64,175,0)_70%)]"></div>

  <div class="relative mx-auto max-w-2xl">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-slate-500">Password recovery</p>
    <h2 class="mt-3 text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">Forgot your password?</h2>
    <p class="mt-3 text-base leading-8 text-slate-700">Enter your email address and we will send reset instructions.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-7 space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "text-sm font-medium text-slate-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-2 block w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-200" %>
      </div>

      <div>
        <%= f.submit "Send me password reset instructions", class: "inline-flex min-h-11 w-full items-center justify-center rounded-full bg-blue-900 px-5 py-2.5 text-sm font-medium text-white transition duration-300 hover:-translate-y-0.5 hover:bg-blue-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-700" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
